# Variables d'environnement — formulaire de contact (Resend)
# Copiez ce fichier en .env (local) ou configurez-les dans Vercel (Production).
# Sans ces variables, le formulaire renvoie « mail_not_configured » proprement.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=contact@dr-wings.com
CONTACT_FROM_EMAIL=Dr Wings <contact@dr-wings.com>
