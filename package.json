    "autostart:uninstall": "powershell -NoProfile -ExecutionPolicy RemoteSigned -File tools/uninstall-autostart.ps1"
  },
  "keywords": [
    "dr-wings",
    "chicken-wings",
    "restaurant",
    "site-vitrine",
    "franconville",
    "uber-eats"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
