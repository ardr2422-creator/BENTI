{
  "name": "dr-wings",
  "version": "1.0.0",
  "description": "Site vitrine premium — Dr Wings, la clinique du poulet à Franconville (95). Chicken wings, livraison Uber Eats. Site statique (HTML/CSS/JS), sans base de données.",
  "private": true,
  "scripts": {
    "dev": "node server.js",
